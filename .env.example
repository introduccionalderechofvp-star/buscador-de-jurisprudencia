OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sentencias
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
PORT=3000

# Migración desde Pinecone (solo necesario para scripts/migrate-pinecone.js)
PINECONE_API_KEY=
PINECONE_HOST=

# ─── Scrapers (opcional) ──────────────────────────────────────────────────────
# Identificación del bot en requests HTTP al API de cada corte. No incluyas
# datos personales — el User-Agent queda en los logs del servidor remoto.
# SCRAPER_USER_AGENT=buscador-jurisprudencia-scraper/1.0

# Tope diario de requests HTTP de los scrapers (por día calendario UTC).
# Previene bugs que podrían disparar tráfico desbocado contra la corte.
# SCRAPER_MAX_REQUESTS_PER_DAY=2000

# Binario de LibreOffice para convertir .docx → .pdf al vuelo. Solo cambiar si
# está instalado en una ruta no estándar (ej. una build compilada custom).
# Instalación estándar en Debian/Ubuntu:
#   apt-get install -y libreoffice-core libreoffice-writer
# LIBREOFFICE_BIN=libreoffice
